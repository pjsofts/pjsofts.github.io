---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="That page doesn't exist. Head back to the AI Engineering course."
  noindex={true}
>
  <section class="nf">
    <div class="wrap narrow ctr">
      <div class="code">404</div>
      <h1>The agent couldn't find that page</h1>
      <p>
        It may have moved, or the link may be wrong. Nothing a step limit and a good
        error message can't handle.
      </p>
      <div class="btns">
        <a class="btn btn-primary" href="/">Back to the course</a>
        <a class="btn btn-ghost" href="/curriculum">See the curriculum</a>
        <a class="btn btn-ghost" href="/blog">Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding: 6rem 0 7rem; }
  .ctr { text-align: center; }
  .code {
    font-family: var(--mono); font-size: 4.5rem; font-weight: 800;
    color: var(--violet); opacity: .55; line-height: 1;
  }
  .nf h1 { margin: 1rem 0 .6rem; font-size: clamp(1.6rem, 4vw, 2.3rem); }
  .nf p { max-width: 46ch; margin: 0 auto 2rem; }
  .btns { display: flex; gap: .7rem; justify-content: center; flex-wrap: wrap; }
</style>
